{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "lkst/callout",
  "title": "Callout",
  "category": "zehoro-toolkit",
  "icon": "info",
  "description": "Visual breaks for long-form content.",
  "attributes": {
    "type": {
      "type": "string",
      "default": "info"
    },
    "content": {
      "type": "string",
      "source": "html",
      "selector": ".lkst-callout-content"
    }
  },
  "editorScript": "file:../callout.js",
  "style": "file:../style-callout.css",
  "textdomain": "zehoro-toolkit"
}