{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "lkst/tldr",
  "title": "TL;DR / Key Takeaways",
  "category": "leokoo-site-toolkit",
  "icon": "list-view",
  "description": "A styled summary box for the top of your articles.",
  "attributes": {
    "heading": {
      "type": "string",
      "default": "Key Takeaways"
    },
    "content": {
      "type": "string",
      "source": "html",
      "selector": ".lkst-tldr-content"
    }
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "textdomain": "leokoo-site-toolkit"
}