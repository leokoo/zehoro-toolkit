{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "lkst/testimonial",
  "title": "Testimonial",
  "category": "leokoo-site-toolkit",
  "icon": "format-quote",
  "description": "Static testimonial card: photo, name, role/company, and quote.",
  "keywords": [
    "testimonial",
    "quote",
    "review",
    "social proof"
  ],
  "attributes": {
    "quote": {
      "type": "string",
      "default": ""
    },
    "name": {
      "type": "string",
      "default": ""
    },
    "role": {
      "type": "string",
      "default": ""
    },
    "company": {
      "type": "string",
      "default": ""
    },
    "imageUrl": {
      "type": "string",
      "default": ""
    },
    "layout": {
      "type": "string",
      "default": "card"
    }
  },
  "supports": {
    "html": false,
    "align": [
      "wide"
    ]
  },
  "editorScript": "file:./index.js",
  "textdomain": "leokoo-site-toolkit"
}