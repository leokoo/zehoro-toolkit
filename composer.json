{
  "name": "leokoo/zehoro-toolkit",
  "description": "Modular utility suite for WordPress sites — composer config for development dependencies only. The plugin itself loads via its own SPL autoloader.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=7.4"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6",
    "yoast/phpunit-polyfills": "^2.0",
    "wp-phpunit/wp-phpunit": "^6.4"
  },
  "scripts": {
    "test": "phpunit",
    "test:unit": "phpunit --testsuite=unit",
    "test:integration": "phpunit --testsuite=integration"
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  }
}
