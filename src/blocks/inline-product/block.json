{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "lkst/inline-product",
  "title": "Inline Product Mention",
  "category": "zehoro-toolkit",
  "icon": "cart",
  "description": "Compact horizontal product card for mid-content references.",
  "keywords": ["product", "affiliate", "mention", "card", "inline"],
  "attributes": {
    "name": {
      "type": "string",
      "default": ""
    },
    "desc": {
      "type": "string",
      "default": ""
    },
    "imageUrl": {
      "type": "string",
      "default": ""
    },
    "imageAlt": {
      "type": "string",
      "default": ""
    },
    "btnText": {
      "type": "string",
      "default": "Check Price"
    },
    "btnUrl": {
      "type": "string",
      "default": ""
    },
    "btnRel": {
      "type": "string",
      "default": "nofollow sponsored"
    }
  },
  "supports": {
    "html": false,
    "align": ["wide"]
  },
  "editorScript": "file:./index.js",
  "textdomain": "zehoro-toolkit"
}
